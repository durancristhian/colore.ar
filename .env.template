# ==============================================================================
# colore.ar – Environment Variables
# ==============================================================================
# Copy this file to `.env` and fill in the values below.
#
#   cp .env.template .env
#
# Each section includes instructions on where to obtain the required keys.
# Variables with a default value already set will work out of the box for
# local development; the rest you must supply yourself.
# ==============================================================================

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------
# Base URL used for absolute links (og images, callbacks, etc.).
# For local development the default below is fine.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Cloudinary – image hosting & transformations
# ------------------------------------------------------------------------------
# 1. Create a free account at https://cloudinary.com/users/register/free
# 2. From your Cloudinary Dashboard (https://console.cloudinary.com/settings/account)
#    copy the **Cloud Name** (shown at the top of the dashboard).
# 3. Go to Settings → Upload → Upload Presets and create an **unsigned** preset.
#    Use the preset name as CLOUDINARY_UPLOAD_PRESET.
# 4. Go to Settings → API Keys (https://console.cloudinary.com/settings/api-keys)
#    and copy the **API Secret** (NOT the API Key) into CLOUDINARY_API_KEY.
#
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME must equal CLOUDINARY_CLOUD_NAME – it is
# exposed to the browser so the upload widget knows which account to use.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ------------------------------------------------------------------------------
# Turso – SQLite database (libSQL)
# ------------------------------------------------------------------------------
# 1. Install the Turso CLI: https://docs.turso.tech/cli/installation
# 2. Sign up / log in:
#      turso auth signup      # or `turso auth login`
# 3. Create a database:
#      turso db create colorear
# 4. Get the connection URL:
#      turso db show colorear --url
#    It looks like: libsql://<db-name>-<org>.turso.io
# 5. Create an auth token:
#      turso db tokens create colorear
#
# Full quickstart: https://docs.turso.tech/quickstart
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ------------------------------------------------------------------------------
# Clerk – authentication
# ------------------------------------------------------------------------------
# 1. Create a free account at https://clerk.com and set up an application.
# 2. In the Clerk dashboard go to **API Keys**
#    (https://dashboard.clerk.com → your app → API Keys).
# 3. Copy the **Publishable key** (starts with `pk_test_` or `pk_live_`).
# 4. Copy the **Secret key** (starts with `sk_test_` or `sk_live_`).
#
# Docs: https://clerk.com/docs/quickstarts/nextjs
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Redirect URLs after sign-in / sign-up – the defaults below send users to
# the main images page. Change them only if your routing differs.
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/imagenes
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/imagenes
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/imagenes
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/imagenes

# ------------------------------------------------------------------------------
# OpenRouter – AI image generation
# ------------------------------------------------------------------------------
# 1. Create an account at https://openrouter.ai
# 2. Go to https://openrouter.ai/keys and create an API key.
# 3. Pick a model that supports image generation. The recommended default is
#    listed below; browse available models at https://openrouter.ai/models
#
# Docs: https://openrouter.ai/docs/quickstart
OPEN_ROUTER_API_KEY=
OPEN_ROUTER_IMAGE_MODEL=google/gemini-3-pro-image-preview

# ------------------------------------------------------------------------------
# Prompt configuration – controls how AI prompts are assembled
# ------------------------------------------------------------------------------
# These values wrap the user's description when generating images.
# The final prompt is: PROMPT_PREFIX + "<user description>" + PROMPT_SUFFIX
# For image-to-image: PROMPT_IMAGE_PREFIX + PROMPT_SUFFIX
#
# The defaults below produce coloring-book-style line art, which is the core
# use case of colore.ar. Tweak them to change the artistic style.
PROMPT_PREFIX=A full-frame coloring book page illustration of:
PROMPT_SUFFIX=. full-frame composition filling the entire canvas edge to edge, coloring book page style, drawn with thick smooth black outlines only, no fills no shading no gradients no grayscale no color no solid areas, every shape defined only by black ink outlines on pure white background, simplified playful rounded cartoon shapes, flat vector-like line art, consistent stroke weight, organic curves, clean readable composition, all areas inside outlines left completely empty and white for manual coloring, vertical portrait orientation, aspect ratio 3:4
PROMPT_IMAGE_PREFIX=Convert this image into a full-frame coloring book page illustration

# ------------------------------------------------------------------------------
# Pollinations – alternative image generation backend
# ------------------------------------------------------------------------------
# Used as an alternative to OpenRouter for image generation.
# 1. Go to https://pollinations.ai
# 2. Sign up and obtain an API key from your account settings.
#
# Docs: https://pollinations.ai/docs
POLLINATIONS_API_KEY=

# ------------------------------------------------------------------------------
# Telegram – feedback notifications (optional)
# ------------------------------------------------------------------------------
# Used to forward user feedback messages to a Telegram chat.
# If left empty the feedback feature will show "temporarily unavailable".
#
# To set this up:
# 1. Open Telegram and search for @BotFather (https://t.me/BotFather).
# 2. Send /newbot and follow the prompts to create a bot.
# 3. BotFather will give you a token like 123456789:ABCdefGhIjKlMnOpQrStUvWxYz.
#    Use the full token as TELEGRAM_BOTID.
# 4. To get your chat ID:
#    a. Start a conversation with your new bot (send it any message).
#    b. Open https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
#    c. Look for "chat":{"id": 123456789, ...} in the JSON response.
#    d. Use that numeric id as TELEGRAM_CHATID.
#
# Reference: https://core.telegram.org/bots#how-do-i-create-a-bot
TELEGRAM_BOTID=
TELEGRAM_CHATID=
