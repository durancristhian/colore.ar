{
  "info": {
    "name": "Printar API",
    "description": "API collection for Printar image endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "imageId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create image",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"a sunset over the sea\"\n}"
        },
        "url": "{{baseUrl}}/api/images",
        "description": "Creates an image from a description. Returns id and url."
      }
    },
    {
      "name": "List images",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/images",
        "description": "Returns all images for the authenticated user."
      }
    },
    {
      "name": "Get image by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/images/{{imageId}}",
        "description": "Returns a single image by id (id, description, imageUrl, createdAt). Set the imageId collection variable (e.g. from Create image response)."
      }
    },
    {
      "name": "Delete image",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/api/images/{{imageId}}",
        "description": "Deletes an image by id. Set the imageId collection variable."
      }
    }
  ]
}