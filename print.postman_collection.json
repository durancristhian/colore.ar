{
    "info": {
        "name": "Print API",
        "description": "API collection for Print image preview endpoints",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000"
        }
    ],
    "item": [
        {
            "name": "Create preview",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"description\": \"a sunset over the sea\"\n}"
                },
                "url": "{{baseUrl}}/api/images",
                "description": "Creates a preview image from a description. Returns id and url to fetch the image."
            }
        }
    ]
}